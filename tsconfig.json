{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "./dist/lib",
    "rootDir": "./src",
    "sourceMap": true,
    "declaration": true,
    "strict": true,
    "strictNullChecks": true,
    "isolatedModules": true,
    "noImplicitAny": true,
    "esModuleInterop": true,
    "removeComments": true,
    "allowSyntheticDefaultImports": true,
    "lib": [
      "es2022"
    ],
    "typeRoots": [
      "./node_modules/@types",
      "./node_modules/@types/**/*"
    ]
  },
  "include": [
    "./src/types.ts",
    "./src/**/*"
  ],
  "exclude": [
    "./node_modules/**/*.tsx",
    "./node_modules/**/*.ts",
    "./node_modules",
    "./bin",
    "./lib",
    "./coverage",
    "./data",
    "./local",
    "./dist",
    "**/*.spec.ts"
  ]
}
